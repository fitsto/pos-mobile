# ===================================================================
# app-mobile — .env.example
# ===================================================================
# Hoy la config vive en `app.json` bajo `expo.extra`. En Fase 2.5 se
# migra a `app.config.js` que lee de estas variables vía `process.env`.
#
# Las variables de Expo accesibles en cliente deben llevar el prefijo
# EXPO_PUBLIC_ para ser embebidas en el bundle.
# ===================================================================

# Backend de tienda (api-pos-negocios)
EXPO_PUBLIC_API_URL="http://localhost:3001"

# Backend de identidad (identity-central) — para login del operador.
EXPO_PUBLIC_IDENTITY_URL="http://localhost:3002"
